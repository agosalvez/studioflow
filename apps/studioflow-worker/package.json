{
  "name": "studioflow-worker",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "build:exe": "pnpm build && pkg dist/index.js --target node20-win-x64 --output release/studioflow-worker.exe --compress GZip",
    "lint": "eslint src/",
    "clean": "rm -rf dist release"
  },
  "pkg": {
    "assets": [],
    "targets": ["node20-win-x64"]
  },
  "dependencies": {
    "amqplib": "^0.10.0",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.0",
    "@types/node": "^20.0.0",
    "@yao-pkg/pkg": "^5.11.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
