# ============================================
# Orderly Worker - Configuración
# ============================================
# Copia este fichero como .env en la misma
# carpeta que orderly-worker.exe
# ============================================

# URL de conexión a RabbitMQ
# Pide estos datos a tu administrador
RABBITMQ_URL=amqp://usuario:contraseña@servidor:5672

# URL interna de la API de Orderly
# Necesaria para generar hojas de trabajo con datos completos
API_INTERNAL_URL=http://servidor:3000

# Clave de autenticación interna entre el worker y la API
# Debe coincidir con INTERNAL_API_KEY configurado en el servidor
INTERNAL_API_KEY=clave_que_te_proporciona_el_administrador
