# ================================
# StudioFlow - Variables de entorno
# ================================
# Copia este fichero como .env y rellena los valores

# --- API ---
API_PORT=3000
DATABASE_URL="mysql://studioflow:password@db:3306/studioflow"
JWT_SECRET="cambia_esto_por_un_secreto_seguro"

# --- Web ---
WEB_PORT=4200
VITE_API_URL="http://localhost:3000"

# --- Worker ---
RABBITMQ_URL="amqp://studioflow:password@rabbitmq:5672"

# --- MySQL ---
MYSQL_ROOT_PASSWORD="root_password"
MYSQL_DATABASE="studioflow"
MYSQL_USER="studioflow"
MYSQL_PASSWORD="password"

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER="studioflow"
RABBITMQ_DEFAULT_PASS="password"
